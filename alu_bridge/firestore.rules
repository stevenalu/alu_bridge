rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /students/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /ventures/{ventureId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.founderUid == request.auth.uid
        && request.resource.data.verification.status == 'pending';
      // A founder can edit or resubmit their venture, but only this project's
      // maintainer (via the Firebase console, which bypasses these rules) can
      // flip verification.status to 'verified'.
      allow update: if request.auth != null
        && request.auth.uid == resource.data.founderUid
        && request.resource.data.verification.status != 'verified';
    }

    match /opportunities/{oppId} {
      allow read: if request.auth != null;
      // Rule: only a verified venture can post a role.
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/ventures/$(request.resource.data.ventureId))
            .data.verification.status == 'verified';
      allow update: if request.auth != null;
    }

    match /applications/{appId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.studentUid == request.auth.uid;
      // Only the venture's founder can move an application through the pipeline.
      allow update: if request.auth != null
        && get(/databases/$(database)/documents/ventures/$(resource.data.ventureId))
            .data.founderUid == request.auth.uid;
    }

    match /conversations/{convId} {
      allow read, update: if request.auth != null && request.auth.uid in resource.data.participants;
      // Rule: a conversation can only be opened once the application is shortlisted or further along.
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && get(/databases/$(database)/documents/applications/$(request.resource.data.applicationId))
            .data.status in ['shortlisted', 'interview', 'offer'];

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in
              get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth != null
          && request.resource.data.senderUid == request.auth.uid
          && request.auth.uid in
              get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }
  }
}
